# Copy to .env and fill in real values. .env is gitignored.

# Database — Neon, Supabase, or local Postgres
POSTGRES_URL=postgres://postgres:postgres@localhost:5432/contacts_dev

# Clerk — https://dashboard.clerk.com → API Keys
CLERK_SECRET_KEY=sk_test_REPLACE_ME
CLERK_PUBLISHABLE_KEY=pk_test_REPLACE_ME

# Vite apps read the publishable key via this prefix
VITE_CLERK_PUBLISHABLE_KEY=pk_test_REPLACE_ME

# Express API base URL
VITE_API_URL=http://localhost:3010

# Optional
# PORT=3010
# FORCED_NETWORK_LATENCY=500   ← artificial per-query delay (ms); omit or set 0 to disable