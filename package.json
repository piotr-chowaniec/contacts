{
  "name": "contacts",
  "private": "true",
  "version": "1.0.0",
  "author": "",
  "license": "ISC",
  "packageManager": "pnpm@10.18.2",
  "type": "module",
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "build": "turbo run build",
    "prepare": "lefthook install",
    "clean": "node scripts/clean",
    "dev": "pnpm turbo run dev",
    "dev:nextjs": "pnpm turbo run dev --filter=nextjs...",
    "dev:remix": "pnpm turbo run dev --filter=remix...",
    "dev:tanstack-router": "pnpm turbo run dev --filter=tanstack-router...",
    "dev:tanstack-start": "pnpm turbo run dev --filter=tanstack-start...",
    "format-and-lint": "biome check .",
		"format-and-lint:fix": "biome check . --write",
    "typecheck": "turbo run typecheck",
    "test": "echo \"Error: no test specified\" && exit 1",
    "test:e2e": "pnpm --filter e2e test:e2e",
    "test:e2e:ui": "pnpm --filter e2e test:e2e:ui"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.16",
    "lefthook": "^2.1.9",
    "commander": "^15.0.0",
    "rimraf": "^6.1.3",
    "turbo": "^2.9.16",
    "typescript": "^6.0.3"
  }
}
